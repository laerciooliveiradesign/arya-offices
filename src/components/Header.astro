---
interface Props {
  active?: 'inicio' | 'sobre' | 'locacoes' | 'contato';
}
const { active } = Astro.props;

const wa = 'https://api.whatsapp.com/send/?phone=5534998293884&text&type=phone_number&app_absent=0&utm_source=site';

const links = [
  { id: 'inicio',   label: 'Início',    href: '/home' },
  { id: 'sobre',    label: 'Sobre',     href: '/sobre' },
  { id: 'locacoes', label: 'Locações',  href: '/locacoes' },
  { id: 'contato',  label: 'Contato',   href: '/contato' },
];
---
<header class="hdr" data-header>
  <div class="hdr__inner container">
    <a class="hdr__logo" href="/home" aria-label="Arya Offices, início">
      <img src="/assets/logo-light.svg" alt="Arya Offices" width="135" height="50" />
    </a>

    <nav class="hdr__nav" aria-label="Navegação principal">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['hdr__link', { 'is-active': active === l.id }]}
          aria-current={active === l.id ? 'page' : undefined}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <button class="hdr__cta" type="button" title="Em breve" aria-label="Área do Cliente (em breve)">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 12.6a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6zM4 20.4C4 16.9 7.6 14.4 12 14.4s8 2.5 8 6v.6H4v-.6z"/></svg>
      <span>Área do Cliente</span>
    </button>

    <button class="hdr__burger" type="button" data-burger aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Menu mobile fullscreen -->
<div class="mnav" id="mobile-menu" data-mobile-menu hidden>
  <nav class="mnav__list" aria-label="Navegação móvel">
    {links.map((l, i) => (
      <a href={l.href} class:list={['mnav__link', { 'is-active': active === l.id }]} style={`--i:${i}`}>
        <span class="mnav__num">0{i + 1}</span>
        {l.label}
      </a>
    ))}
  </nav>
  <div class="mnav__cta">
    <button class="btn btn--outline-gold" type="button" title="Em breve">Área do Cliente</button>
    <a class="btn" href={wa} target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a>
  </div>
  <div class="mnav__foot">
    <span>Polo Tecnológico Sul · Uberlândia/MG</span>
    <div class="mnav__social">
      <a href="https://www.instagram.com/aryaoffices/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.81.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.81-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.81-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.81.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.39C1.34 2.69.93 3.36.62 4.15.32 4.91.12 5.79.07 7.06.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.39 2.13.67.67 1.34 1.08 2.13 1.39.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.31 1.46-.72 2.13-1.39.67-.67 1.08-1.34 1.39-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91-.31-.79-.72-1.46-1.39-2.13C21.32 1.34 20.65.93 19.86.62 19.1.32 18.22.12 16.95.07 15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84zm0 10.16A4 4 0 1 1 16 12a4 4 0 0 1-4 4zm6.41-11.85a1.44 1.44 0 1 0 1.44 1.44 1.44 1.44 0 0 0-1.44-1.44z"/></svg>
      </a>
      <a href="https://www.linkedin.com/company/arya-offices/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
      </a>
    </div>
  </div>
</div>

<style>
  .hdr {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 200; /* acima do menu mobile (.mnav z-index 110) p/ o X ficar clicável */
    height: var(--header-h);
    display: flex;
    align-items: center;
    transition: background var(--t-med) var(--ease), border-color var(--t-med) var(--ease), backdrop-filter var(--t-med) var(--ease);
    border-bottom: 1px solid transparent;
  }
  .hdr.is-scrolled {
    background: rgba(14, 6, 6, 0.82);
    backdrop-filter: blur(14px) saturate(1.2);
    -webkit-backdrop-filter: blur(14px) saturate(1.2);
    border-bottom-color: var(--line-cream-soft);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    width: 100%;
  }
  .hdr__logo { flex: none; transition: opacity var(--t-fast) var(--ease); }
  .hdr__logo:hover { opacity: 0.82; }
  .hdr__logo img { height: 52px; width: auto; }
  @media (max-width: 880px) { .hdr__logo img { height: 50px; } }

  .hdr__nav {
    display: flex;
    align-items: center;
    gap: 2.4rem;
    margin-left: auto;
  }
  .hdr__link {
    position: relative;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream);
    padding-block: 0.4rem;
    transition: color var(--t-fast) var(--ease);
  }
  .hdr__link::after {
    content: "";
    position: absolute; left: 0; bottom: 0;
    width: 100%; height: 1px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--t-med) var(--ease);
  }
  .hdr__link:hover { color: var(--gold-soft); }
  .hdr__link:hover::after,
  .hdr__link.is-active::after { transform: scaleX(1); }
  .hdr__link.is-active { color: var(--gold); }

  .hdr__cta {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.25rem;
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--gold);
    border: 1px solid var(--gold);
    transition: background var(--t-fast) var(--ease);
  }
  .hdr__cta:hover { background: var(--gold-soft); }

  .hdr__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 34px; height: 34px;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    z-index: 120;
  }
  .hdr__burger span {
    width: 24px; height: 1.5px;
    background: var(--cream);
    transition: transform var(--t-med) var(--ease), opacity var(--t-fast) var(--ease);
  }
  body.menu-open .hdr__burger span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  body.menu-open .hdr__burger span:nth-child(2) { opacity: 0; }
  body.menu-open .hdr__burger span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Mobile menu fullscreen */
  .mnav {
    position: fixed;
    inset: 0;
    z-index: 110;
    background: var(--bordo-deep);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.5rem;
    padding: var(--header-h) clamp(1.5rem, 8vw, 4rem) 3rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--t-med) var(--ease), visibility var(--t-med);
  }
  .mnav::before {
    content: "";
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(110% 80% at 80% 10%, rgba(80,21,15,0.6), transparent 60%);
  }
  body.menu-open .mnav { opacity: 1; visibility: visible; }
  .mnav[hidden] { display: flex; }

  .mnav__list { display: flex; flex-direction: column; gap: 0.4rem; position: relative; }
  .mnav__link {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--cream);
    padding-block: 0.9rem;
    border-bottom: 1px solid var(--line-cream-soft);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s var(--ease), transform 0.5s var(--ease), color var(--t-fast) var(--ease);
    transition-delay: calc(var(--i) * 0.06s + 0.1s);
  }
  body.menu-open .mnav__link { opacity: 1; transform: none; }
  .mnav__link:hover, .mnav__link.is-active { color: var(--gold); }
  .mnav__num { font-size: 0.7rem; letter-spacing: 0.2em; color: var(--gold); font-weight: 500; }

  .mnav__cta { position: relative; display: flex; flex-direction: column; gap: 0.75rem; align-items: stretch; }
  .mnav__cta .btn { width: 100%; }
  .mnav__foot {
    position: relative;
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    font-size: var(--fs-small); letter-spacing: 0.12em; text-transform: uppercase; color: var(--stone-dim);
    border-top: 1px solid var(--line-cream-soft); padding-top: 1.5rem;
  }
  .mnav__foot a:hover { color: var(--gold); }
  .mnav__social { display: flex; gap: 1.25rem; }
  .mnav__social a { color: var(--stone); transition: color var(--t-fast) var(--ease); }

  @media (max-width: 880px) {
    .hdr__nav, .hdr__cta { display: none; }
    .hdr__burger { display: flex; }
  }
  @media (min-width: 881px) {
    .mnav { display: none !important; }
  }
</style>

<script>
  // Header sólido ao scrollar
  const header = document.querySelector('[data-header]');
  const onScroll = () => {
    if (window.scrollY > 24) header?.classList.add('is-scrolled');
    else header?.classList.remove('is-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Menu mobile
  const burger = document.querySelector('[data-burger]');
  const menu = document.querySelector('[data-mobile-menu]');
  const toggle = (open: boolean) => {
    document.body.classList.toggle('menu-open', open);
    burger?.setAttribute('aria-expanded', String(open));
    burger?.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');
    document.body.style.overflow = open ? 'hidden' : '';
  };
  burger?.addEventListener('click', () => {
    toggle(!document.body.classList.contains('menu-open'));
  });
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => toggle(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.body.classList.contains('menu-open')) toggle(false);
  });
</script>
