          <a href="https://www.linkedin.com/company/arya-offices/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
        </div>
      </div>

      <div class="ft__col">
        <h4 class="ft__head">Endereço</h4>
        <address>
          Polo Tecnológico Sul<br />
          Uberlândia · MG · Brasil
        </address>
      </div>
    </div>

    <div class="macron ft__macron" aria-hidden="true">
      <span class="macron__dot"></span>
    </div>

    <div class="ft__bottom">
      <p>© {year} Arya Offices · Todos os direitos reservados.</p>
      <p class="ft__credit">Polo Tecnológico Sul · Uberlândia/MG</p>
    </div>
  </div>
</footer>

<style>
  .ft {
    background: var(--bordo-deep);
    color: var(--cream);
    padding-block: clamp(3.5rem, 2rem + 5vw, 6rem) 2.5rem;
    position: relative;
  }
  .ft::before {
    content: "";
    position: absolute; inset: 0 0 auto 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--line-gold), transparent);
  }
  .ft__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: clamp(2rem, 1rem + 3vw, 4rem);
  }
  .ft__brand img { height: 44px; width: auto; margin-bottom: 1.5rem; }
  .ft__tag {
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.5;
    color: var(--stone);
    max-width: 30ch;
  }
  .ft__tag strong { color: var(--gold); font-weight: 500; }

  .ft__col { display: flex; flex-direction: column; gap: 0.85rem; }
  .ft__head {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .ft__col a, .ft__col address {
    font-size: 0.95rem;
    font-weight: 300;
    font-style: normal;
    line-height: 1.7;
    color: var(--stone);
    transition: color var(--t-fast) var(--ease);
  }
  .ft__col a:hover { color: var(--gold); }
  .ft__social { display: flex; gap: 1rem; margin-top: 0.5rem; }
  .ft__social a {
    display: grid; place-items: center;
    width: 42px; height: 42px;
    border: 1px solid var(--line-cream-soft);
    border-radius: var(--btn-shape);
    color: var(--stone);
    transition: color var(--t-fast) var(--ease), border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);
  }
  .ft__social a:hover { color: var(--ink); background: var(--gold); border-color: var(--gold); }

  .ft__macron { margin-block: clamp(2.5rem, 5vw, 4rem); }

  .ft__bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: var(--fs-small);
    letter-spacing: 0.08em;
    color: var(--stone-dim);
  }
  .ft__credit { text-transform: uppercase; letter-spacing: 0.16em; }

  @media (max-width: 880px) {
    .ft__top { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .ft__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .ft__top { grid-template-columns: 1fr; }
    .ft__bottom { flex-direction: column; gap: 0.5rem; }
  }
</style>
